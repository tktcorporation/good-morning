{
  "name": "good-morning",
  "version": "1.0.0",
  "packageManager": "pnpm@10.29.3",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "doctor": "expo doctor"
  },
  "dependencies": {
    "@kingstinct/react-native-healthkit": "^13.2.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "expo": "55.0.3",
    "expo-alarm-kit": "^0.1.6",
    "expo-av": "16.0.8",
    "expo-build-properties": "^55.0.9",
    "expo-constants": "55.0.7",
    "expo-dev-client": "~55.0.10",
    "expo-linking": "55.0.7",
    "expo-localization": "55.0.8",
    "expo-notifications": "55.0.10",
    "expo-router": "55.0.3",
    "expo-splash-screen": "55.0.10",
    "expo-status-bar": "55.0.4",
    "expo-updates": "^55.0.12",
    "i18next": "25.8.13",
    "react": "19.2.0",
    "react-i18next": "16.5.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "2.30.0",
    "react-native-nitro-modules": "^0.34.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-svg": "^15.15.3",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/jest": "29.5.14",
    "@types/react": "19.2.14",
    "babel-preset-expo": "55.0.9",
    "jest": "~29.7.0",
    "jest-expo": "55.0.9",
    "typescript": "5.9.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-alarm-kit",
          "expo-av"
        ]
      }
    }
  },
  "pnpm": {
    "overrides": {
      "tar@<7.5.8": ">=7.5.8"
    }
  },
  "private": true,
  "engines": {
    "pnpm": ">=10"
  }
}
