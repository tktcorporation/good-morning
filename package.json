{
  "name": "good-morning",
  "version": "1.2.2",
  "packageManager": "pnpm@10.29.3",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "ios:release": "expo run:ios --configuration Release --device",
    "ios:local": "eas build --platform ios --profile preview --local --non-interactive",
    "ios:install": "xcrun devicectl device install app --device DB40A4CE-4A0A-550C-B53C-747D13F5D320",
    "android": "expo run:android",
    "web": "expo start --web",
    "screenshots": "node scripts/screenshots.mjs",
    "screenshots:only": "SKIP_SERVER=true node scripts/screenshots.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "doctor": "expo doctor",
    "bundle:check": "expo export --platform ios --output-dir .expo-export-check --no-minify --source-maps && rm -rf .expo-export-check",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "@expo/dom-webview": "~55.0.5",
    "@expo/metro-runtime": "~55.0.10",
    "@kingstinct/react-native-healthkit": "^13.2.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "effect": "^3.20.0",
    "expo": "55.0.19",
    "expo-alarm-kit": "^0.1.6",
    "expo-asset": "~55.0.16",
    "expo-audio": "^55.0.14",
    "expo-background-fetch": "^55.0.15",
    "expo-build-properties": "^55.0.13",
    "expo-constants": "55.0.15",
    "expo-dev-client": "~55.0.30",
    "expo-linking": "55.0.14",
    "expo-localization": "55.0.13",
    "expo-notifications": "55.0.22",
    "expo-router": "55.0.13",
    "expo-sensors": "^55.0.13",
    "expo-splash-screen": "55.0.19",
    "expo-status-bar": "55.0.5",
    "expo-task-manager": "^55.0.15",
    "expo-updates": "^55.0.21",
    "i18next": "25.8.13",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "16.5.4",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "2.30.0",
    "react-native-nitro-modules": "^0.34.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "^0.21.0",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/jest": "29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "babel-preset-expo": "55.0.9",
    "jest": "~29.7.0",
    "jest-expo": "55.0.16",
    "knip": "^5.88.1",
    "playwright": "^1.59.1",
    "react-test-renderer": "19.2.0",
    "typescript": "5.9.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-alarm-kit"
        ]
      }
    }
  },
  "pnpm": {
    "overrides": {
      "tar@<7.5.8": ">=7.5.8",
      "expo-dev-launcher": "55.0.25",
      "expo-dev-menu": "55.0.22"
    },
    "patchedDependencies": {
      "expo-alarm-kit@0.1.6": "patches/expo-alarm-kit@0.1.6.patch"
    }
  },
  "private": true,
  "engines": {
    "pnpm": ">=10"
  }
}
