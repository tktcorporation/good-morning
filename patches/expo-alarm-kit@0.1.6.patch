+    public static func setSnoozeSoundName(_ name: String?) {
+        if let name = name, !name.isEmpty {
+            sharedDefaults?.set(name, forKey: snoozeSoundNameKey)
+        } else {
+            sharedDefaults?.removeObject(forKey: snoozeSoundNameKey)
+        }
+    }
+
+    public static func getSnoozeSoundName() -> String? {
+        return sharedDefaults?.string(forKey: snoozeSoundNameKey)
+    }
